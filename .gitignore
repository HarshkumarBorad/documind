# User-supplied documents in docs/ are NOT committed — they may be third-party
# (arXiv papers, customer docs, etc.) or personal (CVs, contracts). Only the
# .md sample documents that ship with the repo are tracked.
docs/**/*.pdf
docs/**/*.docx
docs/**/*.doc
docs/**/*.odt
