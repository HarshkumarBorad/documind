# --- ChromaDB connection ---
# When running everything in docker-compose, set CHROMA_HOST=chromadb.
# When running app code on host and only ChromaDB in docker, use localhost.
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Namespace prefix ---
# All collection names are prefixed with this. Useful for multi-tenant deploys.
DOCUMIND_NAMESPACE_PREFIX=documind

# --- Hugging Face Inference API (embeddings) ---
# Get a token at https://huggingface.co/settings/tokens — free tier works.
# BGE-M3 is multilingual (German + English).
# If you see 404 / 503 from BGE-M3 on the free serverless API, swap to a smaller
# multilingual model — same code, just a config switch:
#   HF_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HF_TOKEN=
HF_EMBED_MODEL=BAAI/bge-m3

# Batch size for embedding requests. Lower if you hit payload-size errors.
HF_EMBED_BATCH_SIZE=32

# --- Hugging Face Inference API (chat LLM) ---
# Default model used for answer synthesis if --model isn't passed.
# Gated models (Llama, Gemma) require accepting their license on huggingface.co first.
HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_LLM_MAX_TOKENS=512
HF_LLM_TEMPERATURE=0.2

# --- Cross-encoder reranker (Phase 4) ---
# Multilingual reranker — re-scores top retrieval hits to improve precision.
# Default `bge-reranker-base` (~278M params) is CPU-friendly. For higher quality
# at ~2x the cost, swap to BAAI/bge-reranker-v2-m3 (568M params).
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_ENABLED=True
RERANKER_TOP_K=5

# HF Inference Provider for chat completion.
#   "auto" — HF router picks any chat-capable provider (recommended default).
#   "hf-inference" — HF's native serverless. NOTE: no longer hosts the
#     chat-completion task for most popular instruct models (text-generation only).
#   "together" / "fireworks-ai" / "novita" / "nebius" / "sambanova" — partner
#     providers that DO host chat completion. Pin one if "auto" picks an
#     unhealthy provider for your model.
HF_LLM_PROVIDER=auto
